          </conditions>
          <action type="Redirect" url="/ConfiguradorIBRX?HYLN=1.X" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRFKA missing FXLN" stopProcessing="true">
