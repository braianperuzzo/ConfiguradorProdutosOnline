<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.web>
    <httpCookies sameSite="Lax" requireSSL="true" />
      <customErrors mode="On" redirectMode="ResponseRewrite" defaultRedirect="/PaginaErros/PaginaErros.html?code=generic">
          <error statusCode="404" redirect="/PaginaErros/PaginaErros.html?code=404" />
          <error statusCode="500" redirect="/PaginaErros/PaginaErros.html?code=500" />
          <error statusCode="403" redirect="/PaginaErros/PaginaErros.html?code=403" />
          <error statusCode="401" redirect="/PaginaErros/PaginaErros.html?code=401" />
          <error statusCode="502" redirect="/PaginaErros/PaginaErros.html?code=502" />
      </customErrors>
    <globalization culture="pt-BR" uiCulture="pt-BR" />
  </system.web>

<location path="LogsErros/MonitoramentoErros.js">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

<location path="LogsErros">
    <system.web>
      <authorization>
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

    <location path="TokensGeradores">
    <system.web>
      <authorization>
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Configuracoes">
    <system.web>
      <authorization>
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Seguranca">
    <system.web>
      <authorization>
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="ProcessamentoFilaJobs/MetricsFilaJobs.php">
    <system.webServer>
      <security>
        <ipSecurity allowUnlisted="false">
          <add ipAddress="10.0.0.0" subnetMask="255.0.0.0" allowed="true" />
          <add ipAddress="192.168.0.0" subnetMask="255.255.0.0" allowed="true" />
          <add ipAddress="127.0.0.1" allowed="true" />
        </ipSecurity>
      </security>
    </system.webServer>
  </location>

  <location path="APIChat">
    <system.web>
      <customErrors mode="Off" />
    </system.web>
    <system.webServer>
      <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
    </system.webServer>
  </location>

<location path="robots.txt">
    <system.web>
      <customErrors mode="Off" />
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
    <system.webServer>
      <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
      <security>
        <authorization>
          <clear />
          <add accessType="Allow" users="*" />
        </authorization>
      </security>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" cacheControlCustom="public" />
      </staticContent>
    </system.webServer>
  </location>

  <location path="sitemap.xml">
    <system.web>
      <customErrors mode="Off" />
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
    <system.webServer>
      <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
      <security>
        <authorization>
          <clear />
          <add accessType="Allow" users="*" />
        </authorization>
      </security>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="0.01:00:00" cacheControlCustom="public" />
      </staticContent>
    </system.webServer>
  </location>

<location path="sitemap-images.xml">
    <system.web>
      <customErrors mode="Off" />
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
    <system.webServer>
      <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
      <security>
        <authorization>
          <clear />
          <add accessType="Allow" users="*" />
        </authorization>
      </security>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="0.01:00:00" cacheControlCustom="public" />
      </staticContent>
    </system.webServer>
  </location>

 <location path="sitemap-index.xml">
    <system.web>
      <customErrors mode="Off" />
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
    <system.webServer>
      <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
      <security>
        <authorization>
          <clear />
          <add accessType="Allow" users="*" />
        </authorization>
      </security>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="0.01:00:00" cacheControlCustom="public" />
      </staticContent>
    </system.webServer>
  </location>

  <location path=".well-known/assetlinks.json">
    <system.web>
      <customErrors mode="Off" />
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
    <system.webServer>
      <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
      <security>
        <authorization>
          <clear />
          <add accessType="Allow" users="*" />
        </authorization>
      </security>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="0.01:00:00" cacheControlCustom="public" />
      </staticContent>
    </system.webServer>
  </location>

<system.webServer>    
    <rewrite>
    
      <rules>
        <rule name="Redirect www configurador host to canonical host" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^www\.configurador\.redutoresibr\.com\.br$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://configurador.redutoresibr.com.br/{R:1}" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Canonical SEO files on root domain" stopProcessing="true">
          <match url="^(robots\.txt|sitemap(-images|-index)?\.xml)$" ignoreCase="true" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^(www\.)?redutoresibr\.com(\.br)?$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://configurador.redutoresibr.com.br/{R:1}" appendQueryString="false" redirectType="Permanent" />
        </rule>
        <rule name="Serve sitemaps" stopProcessing="true">
          <match url="^sitemap(-images|-index)?\.xml$" />
          <action type="None" />
                  </rule>
        <rule name="Serve robots" stopProcessing="true">
          <match url="^robots\.txt$" />
          <action type="None" />
        </rule>
        <rule name="Serve asset links" stopProcessing="true">
          <match url="^\.well-known/assetlinks\.json$" />
          <action type="None" />
        </rule>
              <rule name="Block sensitive folders" stopProcessing="true">
           <match url="^(LogsErros|TokensGeradores|Configuracoes|Seguranca)(/.*)?$" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/LogsErros/MonitoramentoErros\.js$" negate="true" />
          </conditions>
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access denied." />
        </rule>
        <rule name="Block sensitive file extensions" stopProcessing="true">
          <match url="^.+\.(ini|jwt|log|env|bak|sql)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access denied." />
        </rule>
                <rule name="Allow txt files" stopProcessing="true">
          <match url="^(.+\.txt)$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>
        <rule name="Redirect root domain to configurador" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^(www\.)?redutoresibr\.com(\.br)?$" ignoreCase="true" />
                      </conditions>
          <action type="Redirect" url="https://configurador.redutoresibr.com.br/{R:1}" appendQueryString="true" redirectType="Permanent" />
                  </rule>
        <rule name="Enforce HTTPS" enabled="true" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_X_FORWARDED_PROTO}" pattern="^https$" negate="true" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" appendQueryString="true" redirectType="Permanent" />
          </rule>
        <rule name="Root to app shell" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="/RedutoresIBR.html" />
        </rule>
        <rule name="Cookies modal route" stopProcessing="true">
          <match url="^Cookies/?$" />
          <action type="Rewrite" url="/RedutoresIBR.html" />
        </rule>
        <rule name="Semantic search endpoint (root)" stopProcessing="true">
          <match url="^BuscarSemantico/?$" />
          <action type="Rewrite" url="/PaginasPrincipal/BuscarSemantico.php" />
        </rule>
        <rule name="Memories endpoint (root)" stopProcessing="true">
          <match url="^memories/?$" ignoreCase="true" />
          <action type="Rewrite" url="/APIChat/GerenciarMemorias.php" />
        </rule>
        <rule name="Memory governance endpoint (root)" stopProcessing="true">
          <match url="^memories/governance/?$" ignoreCase="true" />
          <action type="Rewrite" url="/APIChat/MemoryGovernance.php" />
        </rule>
        <rule name="Redirect Buscar to products page" stopProcessing="true">
          <match url="^Buscar/?$" />
          <action type="Redirect" url="/PaginasPrincipal/PaginaProdutos.html" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Metrics fila jobs" stopProcessing="true">
          <match url="^metrics/fila-jobs/?$" />
          <action type="Rewrite" url="/ProcessamentoFilaJobs/MetricsFilaJobs.php" />
        </rule>
        <rule name="LGPD send cookies endpoint" stopProcessing="true">
          <match url="^Cookie/SendCookies/?$" />
          <action type="Rewrite" url="/Cookies/EnviaCookies.php" />
        </rule>
        <rule name="Healthcheck endpoint" stopProcessing="true">
          <match url="^healthz/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REMOTE_ADDR}" pattern="^(127\\.0\\.0\\.1|::1|10\\.|192\\.168\\.|172\\.(1[6-9]|2[0-9]|3[0-1])\\.)" />
          </conditions>
          <action type="Rewrite" url="/PaginasCarregarPagina/Healthcheck.php" />
        </rule>
        <rule name="Healthcheck endpoint blocked" stopProcessing="true">
          <match url="^healthz/?$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access denied." />
        </rule>
        <rule name="Redirect AreaCliente lowercase" stopProcessing="true">
          <match url="^areacliente(/.*)?$" ignoreCase="false" />
          <action type="Redirect" url="/AreaCliente{R:1}" appendQueryString="true" redirectType="Permanent" />
       </rule>
        <rule name="Redirect ConfiguradorIBRMSML to IBRMSI" stopProcessing="true">
          <match url="^ConfiguradorIBRMSML/?$" />
          <action type="Redirect" url="/ConfiguradorIBRMSI" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRT3AT3C to IBRMI" stopProcessing="true">
          <match url="^ConfiguradorIBRT3AT3C/?$" />
          <action type="Redirect" url="/ConfiguradorIBRMI" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRSTANDARD to IBRMI" stopProcessing="true">
          <match url="^ConfiguradorIBRSTANDARD/?$" />
          <action type="Redirect" url="/ConfiguradorIBRMI" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorWEGALTORENDIMENTO to IBRMW" stopProcessing="true">
          <match url="^ConfiguradorWEGALTORENDIMENTO/?$" />
          <action type="Redirect" url="/ConfiguradorIBRMW" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorANTICORROSIVOSAPM to IBRMAPM" stopProcessing="true">
          <match url="^ConfiguradorANTICORROSIVOSAPM/?$" />
          <action type="Redirect" url="/ConfiguradorIBRMAPM" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorANTICORROSIVOSSPM to IBRMSPM" stopProcessing="true">
          <match url="^ConfiguradorANTICORROSIVOSSPM/?$" />
          <action type="Redirect" url="/ConfiguradorIBRMSPM" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRPFFA to IBRFFA" stopProcessing="true">
          <match url="^ConfiguradorIBRPFFA/?$" />
          <action type="Redirect" url="/ConfiguradorIBRFFA" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRXFKA to IBRFKA" stopProcessing="true">
          <match url="^ConfiguradorIBRXFKA/?$" />
          <action type="Redirect" url="/ConfiguradorIBRFKA" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRCFR to IBRFR" stopProcessing="true">
          <match url="^ConfiguradorIBRCFR/?$" />
          <action type="Redirect" url="/ConfiguradorIBRFR" appendQueryString="true" redirectType="Permanent" />
        </rule>

        <!-- Redirect bare configurador URLs to canonical query URLs (SEO canonical consolidation) -->
        <rule name="Redirect ConfiguradorIBRMAPM missing MOLN" stopProcessing="true">
          <match url="^ConfiguradorIBRMAPM/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{QUERY_STRING}" pattern="(^|&amp;)MOLN=" negate="true" />
          </conditions>
          <action type="Redirect" url="/ConfiguradorIBRMAPM?MOLN=3.APM" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRMSPM missing MOLN" stopProcessing="true">
          <match url="^ConfiguradorIBRMSPM/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{QUERY_STRING}" pattern="(^|&amp;)MOLN=" negate="true" />
          </conditions>
          <action type="Redirect" url="/ConfiguradorIBRMSPM?MOLN=3.SPM" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRMI missing MOLN" stopProcessing="true">
          <match url="^ConfiguradorIBRMI/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{QUERY_STRING}" pattern="(^|&amp;)MOLN=" negate="true" />
          </conditions>
          <action type="Redirect" url="/ConfiguradorIBRMI?MOLN=3.I" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRC missing HYLN" stopProcessing="true">
          <match url="^ConfiguradorIBRC/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{QUERY_STRING}" pattern="(^|&amp;)HYLN=" negate="true" />
          </conditions>
          <action type="Redirect" url="/ConfiguradorIBRC?HYLN=1.C" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRFR missing FXLN" stopProcessing="true">
