          </conditions>
          <action type="Redirect" url="/ConfiguradorIBRMSI?MOLN=2.I" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect ConfiguradorIBRV missing VALN" stopProcessing="true">
