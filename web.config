<security>
  <requestFiltering removeServerHeader="true">
    <requestLimits maxQueryString="16384" maxUrl="16384" />
    <fileExtensions>
                    <remove fileExtension=".rules" />
                    <remove fileExtension=".vsdisco" />
                    <remove fileExtension=".msgx" />
                    <remove fileExtension=".compiled" />
                    <remove fileExtension=".refresh" />
                    <remove fileExtension=".exclude" />
                    <remove fileExtension=".lddprototype" />
                    <remove fileExtension=".adprototype" />
                    <remove fileExtension=".sd" />
                    <remove fileExtension=".ldd" />
                    <remove fileExtension=".dd" />
                    <remove fileExtension=".ad" />
                    <remove fileExtension=".ldf" />
                    <remove fileExtension=".mdf" />
                    <remove fileExtension=".sdmDocument" />
                    <remove fileExtension=".sdm" />
                    <remove fileExtension=".lsaprototype" />
                    <remove fileExtension=".dsprototype" />
                    <remove fileExtension=".cd" />
                    <remove fileExtension=".ssmap" />
                    <remove fileExtension=".lsad" />
                    <remove fileExtension=".ssdgm" />
                    <remove fileExtension=".dsdgm" />
                    <remove fileExtension=".ldb" />
                    <remove fileExtension=".jsl" />
                    <remove fileExtension=".java" />
                    <remove fileExtension=".vjsproj" />
                    <remove fileExtension=".mdb" />
                    <remove fileExtension=".resources" />
                    <remove fileExtension=".resx" />
                    <remove fileExtension=".licx" />
                    <remove fileExtension=".webinfo" />
                    <remove fileExtension=".vbproj" />
                    <remove fileExtension=".vb" />
                    <remove fileExtension=".csproj" />
                    <remove fileExtension=".cs" />
                    <remove fileExtension=".browser" />
                    <remove fileExtension=".skin" />
                    <remove fileExtension=".master" />
                    <remove fileExtension=".ascx" />
                    <remove fileExtension=".asax" />
                    <remove fileExtension=".asa" />
                    <remove fileExtension=".config" />
                    <remove fileExtension=".sitemap" />
                    <add fileExtension=".ini" allowed="true" />
                    <add fileExtension=".jwt" allowed="true" />
                    <add fileExtension=".txt" allowed="true" />
                    <add fileExtension=".xml" allowed="true" />
                    <add fileExtension=".sitemap" allowed="true" />
                    <add fileExtension=".robots" allowed="true" />
                    <add fileExtension=".config" allowed="true" />
    </fileExtensions>
    <denyUrlSequences>
      <add sequence="../" />
      <add sequence="&lt;script" />
    </denyUrlSequences>
                <verbs>
                </verbs>
                <hiddenSegments>
                    <remove segment="web.config" />
                    <add segment="web.config" />
                </hiddenSegments>
  </requestFiltering>
</security>
    <directoryBrowse enabled="true" showFlags="Date, Time, Size, Extension, LongDate" />
    <httpProtocol>
        <customHeaders>
          <add name="Strict-Transport-Security" value="max-age=63072000; includeSubDomains; preload" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
          <add name="Permissions-Policy" value="clipboard-read=(self), clipboard-write=(self), geolocation=(self), microphone=()" />
          <remove name="X-Robots-Tag" />
          <add name="X-Robots-Tag" value="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
          <remove name="X-Powered-By" />
        </customHeaders>
    </httpProtocol>
    <defaultDocument>
      <files>
                <clear />
                <add value="RedutoresIBR.html" />
      </files>
    </defaultDocument>
    <httpErrors errorMode="Custom" existingResponse="Replace">
    <remove statusCode="404" />
    <error statusCode="404" path="/PaginaErros/PaginaErros.html?code=404" responseMode="ExecuteURL" />
    <remove statusCode="500" />
    <error statusCode="500" path="/PaginaErros/PaginaErros.html?code=500" responseMode="ExecuteURL" />
    <remove statusCode="403" />
    <error statusCode="403" path="/PaginaErros/PaginaErros.html?code=403" responseMode="ExecuteURL" />
    <remove statusCode="401" />
    <error statusCode="401" path="/PaginaErros/PaginaErros.html?code=401" responseMode="ExecuteURL" />
    <remove statusCode="502" />
    <error statusCode="502" path="/PaginaErros/PaginaErros.html?code=502" responseMode="ExecuteURL" />
</httpErrors>

    <httpCompression directory="%SystemDrive%\inetpub\temp\IIS Temporary Compressed Files">
      <scheme name="br" dll="%Windir%\system32\inetsrv\brotli.dll" />
      <scheme name="gzip" dll="%Windir%\system32\inetsrv\gzip.dll" />
      <scheme name="deflate" dll="%Windir%\system32\inetsrv\gzip.dll" />
      <dynamicTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
    </httpCompression>
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />
        <caching enabled="true" enableKernelCache="true">
     <profiles>
        <add extension=".html" policy="CacheUntilChange" duration="30.00:00:00" />
        <add extension=".css" policy="CacheUntilChange" duration="30.00:00:00" />
        <add extension=".js" policy="CacheUntilChange" duration="30.00:00:00" />
        <add extension=".png" policy="CacheUntilChange" duration="30.00:00:00" />
        <add extension=".jpg" policy="CacheUntilChange" duration="30.00:00:00" />
        <add extension=".webp" policy="CacheUntilChange" duration="30.00:00:00" />
        <add extension=".svg" policy="CacheUntilChange" duration="30.00:00:00" />
      </profiles>
    </caching>
<staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" cacheControlCustom="public" />
      <remove fileExtension=".xml" />
      <mimeMap fileExtension=".xml" mimeType="text/xml" />
            <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
            <remove fileExtension=".txt" />
      <mimeMap fileExtension=".txt" mimeType="text/plain" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>
        <tracing>
            <traceFailedRequests>
                <add path="*">
                    <traceAreas>
                        <add provider="ASP" verbosity="Verbose" />
                        <add provider="ASPNET" areas="Infrastructure,Module,Page,AppServices" verbosity="Verbose" />
                        <add provider="ISAPI Extension" verbosity="Verbose" />
                        <add provider="WWW Server" areas="Authentication,Security,Filter,StaticFile,CGI,Compression,Cache,RequestNotifications,Module,FastCGI,WebSocket,RequestRouting" verbosity="Verbose" />
                    </traceAreas>
                    <failureDefinitions timeTaken="00:00:03" statusCodes="" />
                </add>
            </traceFailedRequests>
        </tracing>
        <httpRedirect enabled="false" destination="" />
      </system.webServer>
      <location path="PaginaErros/PaginaErros.html">
    <system.webServer>
      <applicationInitialization doAppInitAfterRestart="true">
        <add initializationPage="/" />
      </applicationInitialization>

    </system.webServer>
  </location>
    <location path="PaginasSolicitacoes/SolicitacaoCotacao.php">
    <system.web>
      <customErrors mode="On" />
    </system.web>
    <system.webServer>
