    "evento_aba_oculta": {"min": 0.0, "max": 1.0},
    "evento_inatividade": {"min": 0.0, "max": 1.0}
  },
  "mapeamentos": {
    "tempo_parado_ms": {"campo": "tempoParadoMs"},
    "valor_carrinho": {"campo": "valorCarrinho"},
    "quantidade_itens": {"campo": "quantidadeItens"},
