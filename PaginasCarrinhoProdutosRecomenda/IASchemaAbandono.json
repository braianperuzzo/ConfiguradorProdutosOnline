  "limites": {
    "tempo_parado_ms": {"min": 0.0, "max": 14400000.0},
    "valor_carrinho": {"min": 0.0, "max": 1000000.0},
    "quantidade_itens": {"min": 0.0, "max": 500.0},
    "valor_medio_item": {"min": 0.0, "max": 200000.0},
    "tempo_desde_inicio_ms": {"min": 0.0, "max": 28800000.0},
    "total_eventos_sessao": {"min": 0.0, "max": 10000.0},
