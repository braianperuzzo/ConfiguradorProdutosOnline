    "tempo_ativo_total_ms": {"campo": "tempoAtivoTotalMs", "fallback_sessao": "tempo_ativo_total_ms"},
    "profundidade_scroll": {"campo": "profundidadeScroll", "fallback_sessao": "profundidade_scroll"},
    "total_modais_abertos": {"campo": "totalModaisAbertos", "fallback_sessao": "total_modais_abertos"},
    "interacoes_recomendacoes": {"campo": "interacoesRecomendacoes", "fallback_sessao": "interacoes_recomendacoes"},
    "evento_tentativa_saida": {"evento": "tentativa_saida"},
    "evento_aba_oculta": {"evento": "aba_oculta"},
    "evento_inatividade": {"evento": "inatividade"}
  }
